{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dependency-graph.schema.json",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "evidenceId": {
      "type": "string",
      "comment": "Base form (sym|ctor|builder):FQCN:8hex, plus the dependency-graph-only :pN suffix that dependency_graph_extractor.py appends to identify constructor parameter N (see :250). Other schemas keep the strict base form so G2 patch evidence cites whole symbols, not params.",
      "pattern": "^(sym|ctor|builder):[A-Za-z0-9_.$#<>]+:[0-9a-f]{8}(:p[0-9]+)?$"
    }
  },
  "required": [
    "schemaVersion",
    "graphs"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "graphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sut",
          "dependencies"
        ],
        "properties": {
          "sut": {
            "type": "string"
          },
          "instantiationHint": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type",
                "injection"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "injection": {
                  "enum": [
                    "constructor",
                    "field",
                    "setter"
                  ]
                },
                "final": {
                  "type": "boolean"
                },
                "mockable": {
                  "type": "boolean",
                  "description": "True if this type can be mocked with Mockito"
                },
                "evidenceId": {
                  "$ref": "#/definitions/evidenceId",
                  "description": "Evidence ID from the source constructor param"
                }
              }
            }
          },
          "collaboratorUsage": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "field",
                "type",
                "methods"
              ],
              "properties": {
                "field": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "methods": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "evidenceId",
                      "name",
                      "params",
                      "returnType"
                    ],
                    "properties": {
                      "evidenceId": {
                        "$ref": "#/definitions/evidenceId"
                      },
                      "name": {
                        "type": "string"
                      },
                      "params": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "returnType": {
                        "type": "string"
                      },
                      "throws": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "externalClients": {
            "type": "array"
          },
          "springStrategy": {
            "type": "object",
            "properties": {
              "slice": {
                "enum": [
                  "WebMvcTest",
                  "DataJpaTest",
                  "none"
                ]
              },
              "mockBeans": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "exceptions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Union of checked exceptions declared by SUT methods"
          }
        }
      }
    }
  }
}