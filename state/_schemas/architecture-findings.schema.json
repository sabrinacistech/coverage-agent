{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "architecture-findings.schema.json",
  "title": "ArchitectureFindings",
  "description": "Static architecture findings emitted by tools/python/run_architecture_review.py.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "severity",
      "category",
      "title",
      "description",
      "evidence",
      "recommendation",
      "source",
      "confidence"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^arch-[0-9a-f]{12}$"
      },
      "severity": {
        "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "evidence": {
        "type": "array",
        "items": { "type": "string" }
      },
      "recommendation": {
        "type": "string",
        "minLength": 1
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
