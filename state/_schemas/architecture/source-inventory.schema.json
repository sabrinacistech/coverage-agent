{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "architecture/source-inventory.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "repo_uri",
    "host",
    "api_base",
    "owner",
    "repo",
    "branch",
    "output_dir",
    "source_type",
    "rule",
    "files"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "repo_uri": { "type": "string", "minLength": 1 },
    "host": { "type": "string", "minLength": 1 },
    "api_base": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "rule": { "type": "string" },
    "handoff": { "type": "object" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "size"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
