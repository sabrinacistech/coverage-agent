# Copiar a .env y completar. .env está en .gitignore — NUNCA se commitea.

# Proveedor de modelos (vía LiteLLM SDK). Para Anthropic:
ANTHROPIC_API_KEY=sk-ant-...

# Routing de modelos por rol (opcional; ver orchestrator/config.py para defaults).
# Formato LiteLLM "<provider>/<model>".
COVAGENT_MODEL_GENERATION=anthropic/claude-opus-4-8
COVAGENT_MODEL_REPAIR=anthropic/claude-sonnet-4-6

# Observabilidad opcional (M4). Si LANGFUSE_ENABLED!=1, todo es no-op.
LANGFUSE_ENABLED=0
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
