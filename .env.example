# Copiar a .env y completar. .env está en .gitignore — NUNCA se commitea.

# Proveedor de LLM activo (E1.1):
#   ide     → el LLM lo pone Claude Code / GitHub Copilot vía handoff por archivo
#             (sin API key). DEFAULT en etapa 1.
#   litellm → camino autónomo: llama a la API (requiere credenciales abajo).
COVAGENT_LLM_PROVIDER=ide

# Handoff IDE (solo aplica con COVAGENT_LLM_PROVIDER=ide):
# COVAGENT_IDE_DIR=          # default <state>/_llm
# COVAGENT_IDE_TIMEOUT=1800  # segundos máx. esperando la respuesta del IDE

# Credenciales del modelo (solo aplican con COVAGENT_LLM_PROVIDER=litellm).
ANTHROPIC_API_KEY=sk-ant-...

# Routing de modelos por rol (opcional; ver orchestrator/config.py para defaults).
# Formato LiteLLM "<provider>/<model>".
COVAGENT_MODEL_GENERATION=anthropic/claude-opus-4-8
COVAGENT_MODEL_REPAIR=anthropic/claude-sonnet-4-6

# Observabilidad opcional (M4). Si LANGFUSE_ENABLED!=1, todo es no-op.
LANGFUSE_ENABLED=0
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
